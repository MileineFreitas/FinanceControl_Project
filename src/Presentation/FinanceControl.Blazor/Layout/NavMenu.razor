@implements IDisposable
@inject NavigationManager Nav

<div class="nav-root @(Collapsed ? "nav-root--collapsed" : "")">
    <nav class="nav-menu px-2 pt-2 pb-2">
        <!-- Botão de recolher/expandir menu -->
        <button type="button"
                class="nav-collapse-btn nav-link w-100 mb-2 border-0"
                @onclick="ToggleMenuAsync"
                aria-label="@(Collapsed ? "Expandir menu lateral" : "Recolher menu lateral")"
                title="@(Collapsed ? "Expandir menu" : "Recolher menu")">
            @if (Collapsed)
            {
                <svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z" fill="currentColor" />
                </svg>
            }
            else
            {
                <svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z" fill="currentColor" />
                </svg>
            }
            @if (!Collapsed)
            {
                <span class="nav-label">Recolher</span>
            }
        </button>

        <a class="nav-link w-100" href="/home">
            <img class="nav-icon" src="icon-home.png" alt="" />
            <span class="nav-label">Home</span>
        </a>

        <div class="nav-group">
            <button type="button" class="nav-link nav-group-toggle w-100 text-start border-0" @onclick="OnCadastrosHeaderClickAsync" aria-expanded="@cadastrosAberto">
                <img class="nav-icon" src="icon-menu.png" alt="" />
                <span class="nav-label">Cadastros</span>
                <span class="nav-chevron @(cadastrosAberto ? "open" : "")" aria-hidden="true"></span>
            </button>
            @if (cadastrosAberto && !Collapsed)
            {
                <div class="nav-sub">
                    <a class="nav-link nav-sublink w-100" href="/categorias">
                        <span class="nav-sublink-text">Categorias</span>
                    </a>
                    <a class="nav-link nav-sublink w-100" href="/transacoes">
                        <span class="nav-sublink-text">Transações</span>
                    </a>
                </div>
            }
        </div>

        <div class="nav-group">
            <button type="button" class="nav-link nav-group-toggle w-100 text-start border-0" @onclick="OnDashboardsHeaderClickAsync" aria-expanded="@dashboardsAberto">
                <img class="nav-icon" src="icon-relatorio.png" alt="" />
                <span class="nav-label">Dashboards</span>
                <span class="nav-chevron @(dashboardsAberto ? "open" : "")" aria-hidden="true"></span>
            </button>
            @if (dashboardsAberto && !Collapsed)
            {
                <div class="nav-sub">
                    <a class="nav-link nav-sublink w-100" href="/dashboards/geral">
                        <span class="nav-sublink-text">Geral</span>
                    </a>
                    <a class="nav-link nav-sublink w-100" href="/dashboards/por-categoria">
                        <span class="nav-sublink-text">Por categoria</span>
                    </a>
                    <a class="nav-link nav-sublink w-100" href="/dashboards/por-transacoes">
                        <span class="nav-sublink-text">Por transações</span>
                    </a>
                </div>
            }
        </div>
    </nav>
</div>

@code {
    [Parameter]
    public bool Collapsed { get; set; }

    [Parameter]
    public EventCallback<bool> CollapsedChanged { get; set; }

    private bool cadastrosAberto = true;
    private bool dashboardsAberto = true;
    private bool _collapsedPrev;

    protected override void OnParametersSet()
    {
        if (Collapsed && !_collapsedPrev)
        {
            cadastrosAberto = false;
            dashboardsAberto = false;
        }

        _collapsedPrev = Collapsed;
    }

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
        ApplyRouteToGroups(Nav.ToBaseRelativePath(Nav.Uri));
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _ = InvokeAsync(async () =>
        {
            var relative = Nav.ToBaseRelativePath(e.Location);
            if (IsSubMenuRoute(relative) && Collapsed)
                await CollapsedChanged.InvokeAsync(false);

            ApplyRouteToGroups(relative);
            StateHasChanged();
        });
    }

    private static bool IsSubMenuRoute(string relative)
    {
        var r = relative.TrimStart('/').ToLowerInvariant();
        return r.StartsWith("categorias", StringComparison.Ordinal)
               || r.StartsWith("transacoes", StringComparison.Ordinal)
               || r.StartsWith("transactions", StringComparison.Ordinal)
               || r.StartsWith("dashboards/", StringComparison.Ordinal);
    }

    private void ApplyRouteToGroups(string relative)
    {
        var r = relative.TrimStart('/').ToLowerInvariant();
        if (r.StartsWith("categorias", StringComparison.Ordinal)
            || r.StartsWith("transacoes", StringComparison.Ordinal)
            || r.StartsWith("transactions", StringComparison.Ordinal))
        {
            cadastrosAberto = true;
            dashboardsAberto = false;
        }
        else if (r.StartsWith("dashboards/", StringComparison.Ordinal))
        {
            dashboardsAberto = true;
            cadastrosAberto = false;
        }
    }

    private async Task ToggleMenuAsync()
    {
        await CollapsedChanged.InvokeAsync(!Collapsed);
    }

    private async Task OnCadastrosHeaderClickAsync()
    {
        if (Collapsed)
        {
            await CollapsedChanged.InvokeAsync(false);
            cadastrosAberto = true;
            dashboardsAberto = false;
            return;
        }

        cadastrosAberto = !cadastrosAberto;
    }

    private async Task OnDashboardsHeaderClickAsync()
    {
        if (Collapsed)
        {
            await CollapsedChanged.InvokeAsync(false);
            dashboardsAberto = true;
            cadastrosAberto = false;
            return;
        }

        dashboardsAberto = !dashboardsAberto;
    }
}