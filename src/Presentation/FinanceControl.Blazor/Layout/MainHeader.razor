<header class="app-header top-row">
    @* <button type="button" class="menu-toggle-btn" @onclick="ToggleMenu" aria-label="Abrir/Fechar menu" title="Abrir/Fechar menu">
        <svg class="menu-toggle-icon" viewBox="0 0 24 24" aria-hidden="true">
            <path fill="currentColor" d="M3 6h18v2H3V6zm0 5h18v2H3v-2zm0 5h18v2H3v-2z" />
        </svg>
    </button> *@
    <div class="app-header-brand">
        <a class="app-header-title" href="/home">FinanSee</a>
    </div>

    <div class="app-header-actions">
        <div class="header-profile">
            <button type="button"
                    class="header-profile-btn"
                    @onclick="ToggleProfileMenu"
                    aria-expanded="@profileMenuOpen"
                    aria-haspopup="true"
                    title="Menu do perfil"
                    aria-label="Menu do perfil">
                <svg class="header-profile-svg" viewBox="0 0 24 24" aria-hidden="true">
                    <path fill="currentColor" d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
                </svg>
                <span class="header-profile-name">Perfil</span>
            </button>

            @if (profileMenuOpen)
            {
                <button type="button" class="header-dropdown-backdrop" tabindex="-1" aria-label="Fechar menu" @onclick="CloseProfileMenu"></button>
                <div class="header-dropdown header-profile-dropdown" role="menu">
                    <div class="header-dropdown-header">
                        <p class="header-dropdown-username">Meu Perfil</p>
                    </div>
                    <div class="header-dropdown-divider"></div>
                    <NavLink class="header-dropdown-item" href="/perfil" role="menuitem" @onclick="CloseProfileMenu">
                        <svg class="dropdown-item-icon" viewBox="0 0 24 24" aria-hidden="true">
                            <path fill="currentColor" d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
                        </svg>
                        <span>Meu Perfil</span>
                    </NavLink>
                    <NavLink class="header-dropdown-item" href="/configuracoes" role="menuitem" @onclick="CloseProfileMenu">
                        <svg class="dropdown-item-icon" viewBox="0 0 24 24" aria-hidden="true">
                            <path fill="currentColor" d="M19.14 12.94c.04-.31.06-.63.06-.94 0-.31-.02-.63-.06-.94l2.03-1.58a.49.49 0 0 0 .12-.61l-1.92-3.32a.488.488 0 0 0-.59-.22l-2.39.96c-.52-.4-1.08-.73-1.69-.98l-.36-2.54a.484.484 0 0 0-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.61.25-1.17.59-1.69.98l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.04.31-.06.63-.06.94s.02.63.06.94l-2.03 1.58a.49.49 0 0 0-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.52.4 1.08.73 1.69.98l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.61-.25 1.17-.59 1.69-.98l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z" />
                        </svg>
                        <span>Configurações</span>
                    </NavLink>
                    <NavLink class="header-dropdown-item" href="/privacidade" role="menuitem" @onclick="CloseProfileMenu">
                        <svg class="dropdown-item-icon" viewBox="0 0 24 24" aria-hidden="true">
                            <path fill="currentColor" d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z" />
                        </svg>
                        <span>Privacidade</span>
                    </NavLink>
                    <NavLink class="header-dropdown-item" href="/notificacoes" role="menuitem" @onclick="CloseProfileMenu">
                        <svg class="dropdown-item-icon" viewBox="0 0 24 24" aria-hidden="true">
                            <path fill="currentColor" d="M12 22c1.1 0 2-.9 2-2h-4c0 1.1.89 2 2 2zm6-6v-5c0-3.07-1.64-5.64-4.5-6.32V4c0-.83-.67-1.5-1.5-1.5s-1.5.67-1.5 1.5v.68C7.64 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2z" />
                        </svg>
                        <span>Notificações</span>
                    </NavLink>
                    <div class="header-dropdown-divider"></div>
                    <button type="button" class="header-dropdown-item header-dropdown-item-logout" @onclick="OnLogout" role="menuitem">
                        <svg class="dropdown-item-icon" viewBox="0 0 24 24" aria-hidden="true">
                            <path fill="currentColor" d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z" />
                        </svg>
                        <span>Sair</span>
                    </button>
                </div>
            }
        </div>
    </div>
</header>

@code {
    private bool profileMenuOpen;

    [Parameter]
    public bool MenuCollapsed { get; set; }

    [Parameter]
    public EventCallback<bool> MenuCollapsedChanged { get; set; }

    private async Task ToggleMenu()
    {
        await MenuCollapsedChanged.InvokeAsync(!MenuCollapsed);
    }

    private void ToggleProfileMenu() => profileMenuOpen = !profileMenuOpen;

    private void CloseProfileMenu() => profileMenuOpen = false;

    private async Task OnLogout()
    {
        CloseProfileMenu();
    }
}
