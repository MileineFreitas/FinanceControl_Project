<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — FinanceControl</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout-main.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout-nav.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout-header.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/header-dropdown-fix.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="page">
        <div class="sidebar p-2" id="fc-sidebar">
            <partial name="_Nav" />
        </div>
        <main>
            <partial name="_MainHeader" />
            <article class="content px-4">
                @RenderBody()
            </article>
        </main>
    </div>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
