@page "/register"
@model FinanceControl.Web.Pages.RegisterModel
@{
    Layout = "/Pages/Shared/_LayoutAuth.cshtml";
    ViewData["Title"] = "Cadastre-se";
}
@section Styles {
    <link rel="stylesheet" href="~/css/register.css" asp-append-version="true" />
}

<div class="page">
    <div class="card">
        <div class="header">
            <h1>Criar conta</h1>
            <p>Preencha os campos abaixo para se cadastrar</p>
        </div>

        <form method="post" enctype="multipart/form-data" class="register-form">
            <div class="avatar-section">
                <label asp-for="ProfilePhotoFile" class="avatar-wrapper" style="cursor:pointer">
                    <div class="avatar-circle" id="fc-avatar-preview-wrap">
                        <div class="avatar-icon" id="fc-avatar-placeholder">
                            <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                            </svg>
                        </div>
                        <img id="fc-avatar-img" alt="Foto de perfil" style="display:none;width:100%;height:100%;object-fit:cover;border-radius:50%;" />
                    </div>
                    <div class="avatar-badge">
                        <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 0 1 5.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 0 0-1.134-.175 2.31 2.31 0 0 1-1.64-1.055l-.822-1.316a2.192 2.192 0 0 0-1.736-1.039 48.774 48.774 0 0 0-5.232 0 2.192 2.192 0 0 0-1.736 1.039l-.821 1.316Z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 1 1-9 0 4.5 4.5 0 0 1 9 0ZM18.75 10.5h.008v.008h-.008V10.5Z" />
                        </svg>
                    </div>
                </label>
                <input asp-for="ProfilePhotoFile" accept="image/*" class="d-none" />
                <span class="avatar-label">Clique para adicionar foto de perfil</span>
            </div>

            <div class="field">
                <label asp-for="Register.UserName">Nome de usuário</label>
                <div class="input-wrapper">
                    <input asp-for="Register.UserName" class="form-control" placeholder="user.name" />
                </div>
                <span asp-validation-for="Register.UserName" class="validation-msg"></span>
            </div>

            <div class="field">
                <label asp-for="Register.Email">E-mail</label>
                <div class="input-wrapper">
                    <input asp-for="Register.Email" class="form-control" type="email" placeholder="seu@email.com" />
                </div>
                <span asp-validation-for="Register.Email" class="validation-msg"></span>
            </div>

            <div class="field">
                <label asp-for="Register.Password">Senha</label>
                <div class="input-wrapper">
                    <input asp-for="Register.Password" type="password" id="Register_Password" class="form-control" placeholder="mínimo 8 caracteres" />
                    <button type="button" class="eye-btn" id="fc-toggle-pwd" aria-label="Mostrar ou ocultar senha">
                        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="Register.Password" class="validation-msg"></span>
                <div class="strength-bar" id="fc-strength-bar" hidden>
                    <span data-bar="1"></span><span data-bar="2"></span><span data-bar="3"></span><span data-bar="4"></span>
                </div>
                <div class="strength-label" id="fc-strength-label"></div>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="error-banner">@Model.ErrorMessage</div>
            }

            <button type="submit" class="btn-submit">Criar conta</button>
        </form>

        <div class="footer-text">
            Já tem uma conta? <a href="/">Entrar</a>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/register.js" asp-append-version="true"></script>
}
